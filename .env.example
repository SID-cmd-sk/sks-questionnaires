# ============================================================
# SKS Scantech — Environment Variables Reference
# ============================================================
# This file is for REFERENCE ONLY.
# Never commit real values.
#
# For GitHub Actions: add as Repository Secrets
#   Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # safe in browser
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # SECRET — Actions only

# ── EmailJS ──────────────────────────────────────────────────
# EmailJS Dashboard → Email Services / Templates / Account → API Keys

EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx        # Admin notification template
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx      # Public key (safe in browser)

# ── Google Apps Script Web App URL ───────────────────────────
# Extensions → Apps Script → Deploy → Web App → copy URL
# This ONE URL handles both Drive upload and Sheets logging.

GSHEET_WEBAPP_URL=https://script.google.com/macros/s/AKfycb.../exec

# ── GitHub Actions ────────────────────────────────────────────
# Set in GitHub → Settings → Secrets → Actions
# GITHUB_TOKEN is automatic — no extra token needed for Actions itself.
# You only need a PAT for the Supabase → webhook → GitHub dispatch link.
