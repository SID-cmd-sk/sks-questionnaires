# ============================================================
# SKS Scantech — Environment Variables Reference
# ============================================================
# This file is for REFERENCE ONLY.
# Never commit real values to git.
#
# For GitHub Actions: add these as Repository Secrets
#   Settings → Secrets and variables → Actions → New repository secret
#
# For local Python processor: set as OS environment variables
#   Windows:  setx SUPABASE_URL "https://xxxx.supabase.co"
#   Linux:    export SUPABASE_URL="https://xxxx.supabase.co"
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...      # Safe in browser (anon/public)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # SECRET — server/Actions only

# ── Cloudinary ───────────────────────────────────────────────
# Found in: Cloudinary Dashboard → Settings → Upload → Upload Presets
# Create an UNSIGNED preset for browser uploads

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=sks_unsigned_uploads    # Must be "unsigned" mode

# ── EmailJS ──────────────────────────────────────────────────
# Found in: EmailJS Dashboard → Account → API Keys
# Create two templates:
#   1. Customer confirmation (template_params: to_name, request_id, machine_list)
#   2. Admin notification   (template_params: request_id, customer_name, zip_url, dashboard_url)

EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx          # Customer confirmation template
EMAILJS_TEMPLATE_ADMIN_ID=template_yyyyyyy    # Admin notification template
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx        # Public key (safe in browser)

# ── Google Sheets ─────────────────────────────────────────────
# Deploy google_apps_script.gs as a Web App (see docs/SETUP_GUIDE.md)
# Execution: Me | Access: Anyone

GSHEET_WEBAPP_URL=https://script.google.com/macros/s/AKfycb.../exec

# ── GitHub Actions (used automatically from Secrets) ─────────
# These are set in GitHub → Settings → Secrets → Actions
# They do NOT go into env.js or any committed file

# GH_PAT is NOT needed — GitHub Actions uses GITHUB_TOKEN automatically
